PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/campusprint

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_key_here

# Email — option 1: Resend (preferred for production)
# Sign up at https://resend.com, verify your domain, then paste the API key.
RESEND_API_KEY=re_your_api_key_here

# Email — option 2: Nodemailer / SMTP (used when RESEND_API_KEY is not set)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=CampusPrint <your@gmail.com>

# Admin email (receives order notifications; defaults to EMAIL_USER if not set)
ADMIN_EMAIL=admin@your-domain.com

# Admin JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=change_this_to_a_long_random_string

# AWS S3 — for production file storage (optional; falls back to local disk when not set)
# Create a private S3 bucket and an IAM user with s3:PutObject / s3:GetObject / s3:DeleteObject.
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=campusprint-uploads
