PORT=5000
NODE_ENV=development

# ── Supabase PostgreSQL (replaces MongoDB) ──────────────────────────────────
# Create a project at https://supabase.com, run supabase/schema.sql in SQL Editor
# Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co
# Settings → API → service_role secret (NOT the anon key)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-key-here

# ── Uploadcare (file storage, delivery, and previews) ───────────────────────
# Create a free account at https://uploadcare.com → Dashboard → API Keys
UPLOADCARE_PUBLIC_KEY=your_public_key_here
UPLOADCARE_SECRET_KEY=your_secret_key_here

# ── Auth.js session secret ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
AUTH_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# ── JWT (API Bearer tokens, used alongside Auth.js cookie sessions) ──────────
JWT_SECRET=change_this_to_a_long_random_string

# ── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_key_here
PAYSTACK_CALLBACK_URL=https://your-domain.com/

# ── Resend (transactional email — preferred) ─────────────────────────────────
# Sign up at https://resend.com, verify your domain, paste your API key
RESEND_API_KEY=re_your_api_key_here

# ── Nodemailer / SMTP (fallback when RESEND_API_KEY is not set) ──────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=CampusPrint <your@gmail.com>

# ── Admin notifications ───────────────────────────────────────────────────────
ADMIN_EMAIL=admin@your-domain.com
