# ─────────────────────────────────────────────
#  CampusPrint – Environment Variables
#  Copy to .env and fill in real values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=production

# ─── MongoDB Atlas ────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/campusprint?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://campusprint_user:YOURPASSWORD@cluster0.xxxxx.mongodb.net/campusprint?retryWrites=true&w=majority

# ─── Paystack ─────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_YOUR_PAYSTACK_SECRET_KEY_HERE
PAYSTACK_PUBLIC_KEY=pk_live_YOUR_PAYSTACK_PUBLIC_KEY_HERE

# ─── Email (Gmail App Password) ───────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=CampusPrint <your@gmail.com>

# ─── Admin ────────────────────────────────────
# Generate with: openssl rand -base64 32
ADMIN_SECRET=replace_with_a_strong_random_secret

# ─── CORS (production domain) ─────────────────
ALLOWED_ORIGINS=https://campusprint.store,https://www.campusprint.store
